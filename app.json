{
  "expo": {
    "name": "EthicScan",
    "slug": "EthicScan",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "ethicscan",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "EthicScan needs camera access to scan product barcodes."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1B5E20",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": ["android.permission.CAMERA"]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "EthicScan needs camera access to scan product barcodes.",
          "barcodeScannerEnabled": true
        }
      ],
      "expo-status-bar",
      "expo-font",
      "expo-splash-screen"
    ]
  }
}
